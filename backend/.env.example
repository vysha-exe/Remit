PORT=4000

# Contact / assistant chat: set OPENAI_API_KEY for GPT replies (server-side only; never commit real keys).
# If unset, /api/chat uses built-in rule-based answers.
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: send confirmation email when the user enters "Confirmation email" on send (nodemailer + SMTP).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=Remit <noreply@example.com>
# Link in email for Track (your deployed frontend base URL, no trailing slash):
# PUBLIC_APP_URL=https://your-app.vercel.app

MONGODB_URI=mongodb+srv://USER:<db_password>@cluster.mongodb.net/?appName=Cluster0

# Required for sign up / sign in (JWT). Use a long random string in production.
# JWT_SECRET=
# JWT_EXPIRES_IN=7d
TRON_FULL_HOST=https://api.nileex.io
TRON_PRIVATE_KEY=
TRON_RECEIVER_ADDRESS=
# Optional: Nile TRC-20 — either mint (ProximityStable you deploy) or transfer (e.g. USDT; fund wallet first).
# Deploy: cd backend && npm run compile:contract && npm run deploy:stable  (needs Nile TRX on TRON_PRIVATE_KEY)
# TRON_STABLE_CONTRACT=
# true = call mint(receiver, amount) — deployer key must own the contract. false/omit = transfer() from balance.
# TRON_STABLE_USE_MINT=false
# Smallest units (ProximityStable/USDT 6 decimals: 1000 = 0.001 token)
# TRON_STABLE_TRANSFER_AMOUNT=1000
# TRON_STABLE_FEE_LIMIT=150000000
# Higher fee limit for contract creation only:
# TRON_STABLE_DEPLOY_FEE_LIMIT=200000000

# Public FX rates (no API key). Used by /api/send when COINBASE_ENABLED=true.
COINBASE_ENABLED=true
COINBASE_STRICT=false
COINBASE_BASE_URL=https://api.coinbase.com

# Advanced Trade (CDP): JWT auth, real brokerage API. Key from Developer Platform (organizations/.../apiKeys/...).
COINBASE_ADVANCED_TRADE_ENABLED=false
COINBASE_CDP_API_KEY_ID=
COINBASE_CDP_API_KEY_SECRET=
# Optional: max USD per POST /api/coinbase-advanced/market-buy-usdc (default 100).

BYBIT_ENABLED=false
BYBIT_STRICT=false

# US→UK cashout: default is local demo timers. For real Wise sandbox API calls:
# PAYOUT_US_UK_MODE=wise_sandbox
# (legacy alias: PAYOUT_UK_US_MODE=wise_sandbox)
# WISE_API_TOKEN=your_personal_token_from_wise_sandbox
# WISE_API_BASE=https://api.wise-sandbox.com
# WISE_PROFILE_ID=          # optional if you have multiple profiles
# WISE_PROFILE_TYPE=personal # or business
# WISE_DEFAULT_US_ADDRESS_LINE=1 Sandbox Street
# WISE_DEFAULT_US_CITY=New York
# WISE_DEFAULT_US_STATE=NY
# WISE_DEFAULT_US_ZIP=10001
